# Frontend Environment Variables Template - Copy to .env and fill in values

# API Configuration (from CDK output after deployment)
REACT_APP_API_ENDPOINT=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod

# AWS Cognito Configuration (from CDK output after deployment)
REACT_APP_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
REACT_APP_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
REACT_APP_COGNITO_REGION=us-east-1

# AWS Region
REACT_APP_AWS_REGION=us-east-1

# Stripe Configuration
# Get publishable key from https://dashboard.stripe.com/test/apikeys
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Optional: Google Maps API Key for enhanced mapping features
# REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
