# Environment Variables Template - Copy to .env and fill in values

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# DynamoDB Tables (will be created by CDK)
LEADS_TABLE_NAME=RealtorLeads
AGENTS_TABLE_NAME=RealtorAgents
TRANSACTIONS_TABLE_NAME=RealtorTransactions

# AWS Location Service (will be created by CDK)
PLACE_INDEX_NAME=RealtorPlaceIndex
ROUTE_CALCULATOR_NAME=RealtorRouteCalculator

# Amazon Bedrock Configuration
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0
BEDROCK_FALLBACK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Stripe Configuration
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Application Configuration
PRICE_PER_POINT=10
DEFAULT_RADIUS_MILES=15
MIN_RADIUS_MILES=5
MAX_RADIUS_MILES=40
LEAD_EXPIRY_HOURS=72

# Node Environment
NODE_ENV=production
