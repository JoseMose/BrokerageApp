# ─── IBM Cloudant ────────────────────────────────────────────────────────────
CLOUDANT_URL=https://<instance-id>.cloudantnosqldb.appdomain.cloud
CLOUDANT_API_KEY=

# ─── IBM App ID ──────────────────────────────────────────────────────────────
APP_ID_TENANT_ID=
APP_ID_CLIENT_ID=
APP_ID_SECRET=
APP_ID_REGION=us-south

# ─── IBM WatsonX AI ──────────────────────────────────────────────────────────
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_REGION=us-south
WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2

# ─── HERE Maps ───────────────────────────────────────────────────────────────
HERE_API_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── IBM Cloud Email Delivery (SendGrid API) ─────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@jesfandiari.com
SUPPORT_EMAIL=joseph@jesfandiari.com

# ─── IBM Event Notifications (SMS) ───────────────────────────────────────────
IBM_EN_API_KEY=
IBM_EN_INSTANCE_GUID=
IBM_EN_SOURCE_ID=
IBM_EN_REGION=us-south

# ─── IBM Cloud Object Storage ────────────────────────────────────────────────
COS_BUCKET=je-brokerage-docs
COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
COS_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ─── Cloudant DB names (optional overrides) ──────────────────────────────────
LEADS_TABLE_NAME=RealtorLeads
AGENTS_TABLE_NAME=RealtorAgents
TRANSACTIONS_TABLE_NAME=RealtorTransactions
MASTER_LEADS_TABLE_NAME=MasterLeads
AGENT_FUNNEL_TABLE_NAME=AgentFunnel
PRICE_PER_POINT=10
DEFAULT_RADIUS_MILES=15
LEAD_EXPIRY_HOURS=72
